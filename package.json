{
  "name": "snowztech-ui-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "dev": "pnpm --parallel --filter ./apps/* --filter ./packages/* dev",
    "dev:docs": "pnpm --filter docs dev",
    "dev:ui": "pnpm --filter @snowztech/ui dev",
    "typecheck": "pnpm -r typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "publish:all": "pnpm build && pnpm -F @snowztech/ui-css publish --access public --no-git-checks && pnpm -F @snowztech/ui-js publish --access public --no-git-checks && pnpm -F @snowztech/ui publish --access public --no-git-checks"
  },
  "packageManager": "pnpm@10.17.1",
  "devDependencies": {
    "@changesets/cli": "^2.31.0"
  }
}
