{
  "name": "@snowztech/ui-css",
  "version": "0.3.0",
  "description": "Terminal-minimal CSS design system. Tokens, resets, and component classes. Framework-agnostic.",
  "license": "MIT",
  "author": {
    "name": "Lucas Neves Pereira",
    "email": "lnevespereira@proton.me",
    "url": "https://github.com/lucasnevespereira"
  },
  "homepage": "https://github.com/snowztech/ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snowztech/ui.git",
    "directory": "packages/ui-css"
  },
  "bugs": {
    "url": "https://github.com/snowztech/ui/issues"
  },
  "keywords": [
    "design-system",
    "css",
    "tokens",
    "snowztech",
    "terminal",
    "minimal"
  ],
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/snowztech-ui.css",
    "./min": "./dist/snowztech-ui.min.css",
    "./tokens": "./dist/tokens.css",
    "./tokens.css": "./dist/tokens.css",
    "./base": "./dist/base.css",
    "./base.css": "./dist/base.css",
    "./styles.css": "./dist/snowztech-ui.css",
    "./components/*": "./dist/components/*.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "esbuild": "^0.27.7"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css"
  ]
