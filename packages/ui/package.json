{
  "name": "@snowztech/ui",
  "version": "0.1.0",
  "description": "Terminal-minimal React design system. Mark, icons, tokens, and primitives.",
  "license": "MIT",
  "author": {
    "name": "Lucas Neves Pereira",
    "email": "lnevespereira@proton.me",
    "url": "https://github.com/lucasnevespereira"
  },
  "homepage": "https://github.com/snowztech/ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snowztech/ui.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/snowztech/ui/issues"
  },
  "keywords": [
    "design-system",
    "react",
    "components",
    "ui",
    "icons",
    "tokens",
    "css",
    "terminal",
    "minimal",
    "snowztech"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/tokens.css",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./tokens.css": "./src/tokens.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "react": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
