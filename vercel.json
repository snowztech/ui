{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @snowztech/ui-css --filter @snowztech/ui-js --filter @snowztech/ui build && pnpm --filter docs build",
  "outputDirectory": "apps/docs/.next"
}
